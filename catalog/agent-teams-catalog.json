      "aggregator": {
        "id": "aggregator",
        "source": "import",
        "updatedAt": "2026-03-19T00:34:47.364Z",
        "data": {
          "id": "aggregator",
          "name": "Aggregator",
          "version": "1.0.0",
          "role": "worker",
          "domain": "general",
          "description": "Collects the results of parallel sub-tasks from Engram, merges them into a unified coherent outcome, and writes the consolidated result to task:{taskId}:result. Triggered automatically by TaskCoordinator when all parallel subtasks have completed.\n",
          "expertise": [
            "result aggregation",
            "Engram memory recall",
            "parallel task coordination",
            "summary generation",
            "cross-domain result unification"
          ],
          "intents": [
            "aggregate_parallel_results",
            "merge_subtask_outputs",
            "write_final_result"
          ],
          "scope": {
            "topics": [
              "parallel sub-task result aggregation",
              "result unification across domains"
            ]
          },
          "workflow": [
            "Recall all task:{taskId}:subtask:*:result entries from Engram.",
            "Identify which sub-tasks have completed and which (if any) are missing.",
            "Merge all results into a coherent unified outcome, resolving any conflicts.",
            "Write the final aggregated result to Engram as task:{taskId}:result.",
            "Present a structured summary listing each completed sub-task and its contribution."
          ],
          "tools": [
            {
              "name": "search/codebase"
            }
          ],
          "permissions": {
            "can_create_files": false,
            "can_edit_files": false,
            "can_delete_files": false,
            "can_run_commands": false,
            "can_delegate": false,
            "can_modify_public_api": false,
            "can_touch_global_config": false
          },
          "engram": {
            "mode": "autonomous"
          },
          "mcpServers": [
            {
              "id": "engram",
              "command": "engram",
              "args": []
            }
          ],
          "handoffs": {
            "receives_from": [
              "router"
            ]
          },
          "output": {
            "template": "summary",
            "mode": "detailed",
            "max_items": 10
          }
        }
      },
      "api-worker": {
        "id": "api-worker",
        "source": "import",
        "updatedAt": "2026-03-19T00:34:47.364Z",
        "data": {
          "id": "api-worker",
          "name": "API Worker",
          "version": "1.0.0",
          "role": "worker",
          "domain": "backend",
          "subdomain": "api",
          "description": "Creates and modifies API endpoints, middleware, and authentication handlers in src/api/ using TypeScript. Follows existing module patterns and ensures proper input validation and error handling.\n",
          "expertise": [
            "TypeScript",
            "REST API design",
            "middleware patterns",
            "authentication and JWT",
            "input validation",
            "error handling"
          ],
          "intents": [
            "create_endpoint",
            "modify_endpoint",
            "add_middleware",
            "implement_authentication",
            "add_user_route"
          ],
          "scope": {
            "topics": [
              "API endpoint implementation",
              "middleware development",
              "authentication handler implementation"
            ],
            "path_globs": [
              {
                "pattern": "src/api/**",
                "priority": "high"
              }
            ],
            "excludes": [
              "dist/**",
              "node_modules/**"
            ]
          },
          "workflow": [
            "Read existing files in src/api/ to understand module structure and conventions.",
            "Implement the requested endpoint or middleware following existing patterns.",
            "Ensure all inputs are validated at API boundaries.",
            "Add proper error handling with appropriate HTTP status codes.",
            "Write a backend:patterns entry to Engram recording key implementation decisions."
          ],
          "tools": [
            {
              "name": "search/codebase"
            },
            {
              "name": "edit/editFiles"
            }
          ],
          "permissions": {
            "can_create_files": true,
            "can_edit_files": true,
            "can_delete_files": false,
            "can_run_commands": false,
            "can_delegate": false,
            "can_modify_public_api": false,
            "can_touch_global_config": false
          },
          "constraints": {
            "always": [
              "Validate all user input at API boundaries.",
              "Follow the module structure and naming conventions in src/api/.",
              "Return consistent error response shapes."
            ],
            "never": [
              "Hardcode credentials, secrets, or tokens in source files.",
              "Create files outside src/api/."
            ]
          },
          "handoffs": {
            "receives_from": [
              "backend-orchestrator"
            ]
          },
          "output": {
            "template": "diff",
            "mode": "detailed",
            "max_items": 10
          }
        }
      },
      "backend-orchestrator": {
        "id": "backend-orchestrator",
        "source": "import",
        "updatedAt": "2026-03-19T00:34:47.364Z",
        "data": {
          "id": "backend-orchestrator",
          "name": "Backend Orchestrator",
          "version": "1.0.0",
          "role": "orchestrator",
          "domain": "backend",
          "description": "Decomposes backend feature requests into API-level sub-tasks and delegates them to the api-worker. Integrates results and validates the delivered backend feature end-to-end.\n",
          "expertise": [
            "REST API design",
            "TypeScript",
            "API task decomposition",
            "middleware planning",
            "authentication flows"
          ],
          "intents": [
            "orchestrate_api_implementation",
            "orchestrate_backend_feature",
            "delegate_backend_subtasks"
          ],
          "scope": {
            "topics": [
              "API endpoint development",
              "middleware implementation",
              "authentication and authorization",
              "backend architecture planning"
            ]
          },
          "workflow": [
            "Recall the task context from Engram using task:{taskId}:subtask:backend (parallel) or handoff:{taskId} (single).",
            "Analyze the request and identify all API artifacts that need to be created or modified.",
            "Decompose into endpoint-level sub-tasks and delegate each to api-worker.",
            "Integrate returned results and verify the backend feature is complete.",
            "Write the final outcome to Engram as task:{taskId}:subtask:backend:result and call complete_subtask."
          ],
          "tools": [
            {
              "name": "search/codebase"
            }
          ],
          "permissions": {
            "can_delegate": true
          },
          "handoffs": {
            "receives_from": [
              "router"
            ],
            "delegates_to": [
              "api-worker"
            ]
          },
          "output": {
            "template": "planning",
            "mode": "detailed"
          }
        }
      },
      "component-worker": {
        "id": "component-worker",
        "source": "import",
        "updatedAt": "2026-03-19T00:34:47.364Z",
        "data": {
          "id": "component-worker",
          "name": "Component Worker",
          "version": "1.0.0",
          "role": "worker",
          "domain": "frontend",
          "subdomain": "components",
          "description": "Creates and modifies React components with TypeScript in src/ui/. Generates component files with typed props interfaces, requested variants, and corresponding Vitest + Testing Library test files.\n",
          "expertise": [
            "React 18",
            "TypeScript",
            "Vitest",
            "Testing Library",
            "CSS-in-JS / inline styles",
            "component API design",
            "variant patterns (primary/secondary)"
          ],
          "intents": [
            "create_component",
            "modify_component",
            "add_component_variant",
            "write_component_tests"
          ],
          "scope": {
            "topics": [
              "React component implementation",
              "component testing",
              "component variant design"
            ],
            "path_globs": [
              {
                "pattern": "src/ui/**",
                "priority": "high"
              },
              {
                "pattern": "src/**/*.test.tsx",
                "priority": "medium"
              }
            ],
            "excludes": [
              "dist/**",
              "node_modules/**"
            ]
          },
          "workflow": [
            "Read existing components in src/ui/ to understand naming and structuring conventions.",
            "Implement the requested component with TypeScript props interface and all requested variants.",
            "Create a co-located .test.tsx file following the Button.test.tsx / Card.test.tsx patterns.",
            "Write a frontend:patterns entry to Engram recording the key design decisions made."
          ],
          "tools": [
            {
              "name": "search/codebase"
            },
            {
              "name": "edit/editFiles"
            }
          ],
          "permissions": {
            "can_create_files": true,
            "can_edit_files": true,
            "can_delete_files": false,
            "can_run_commands": false,
            "can_delegate": false,
            "can_modify_public_api": false,
            "can_touch_global_config": false
          },
          "constraints": {
            "always": [
              "Follow the naming and file structure conventions already present in src/ui/.",
              "Add a Vitest test file for every new component.",
              "Use TypeScript interfaces for all component props.",
              "Export components as named exports."
            ],
            "never": [
              "Create files outside src/.",
              "Use default exports for components."
            ]
          },
          "handoffs": {
            "receives_from": [
              "frontend-orchestrator"
            ]
          },
          "output": {
            "template": "diff",
            "mode": "detailed",
            "max_items": 10
          }
        }
      },
