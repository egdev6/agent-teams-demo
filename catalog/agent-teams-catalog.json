      "router": {
        "id": "router",
        "source": "import",
        "updatedAt": "2026-03-19T00:34:47.364Z",
        "data": {
          "id": "router",
          "name": "Router",
          "version": "1.0.0",
          "role": "router",
          "domain": "global",
          "description": "Receives all incoming user requests, classifies the intent, and routes to the appropriate orchestrator or worker agent. Supports single-domain handoff and multi-domain parallel dispatch via Agent Teams protocol.\n",
          "expertise": [
            "intent classification",
            "request routing",
            "single-domain handoff",
            "multi-domain parallel dispatch",
            "Engram handoff context writing"
          ],
          "intents": [
            "component_creation",
            "api_implementation",
            "ui_analysis",
            "parallel_dispatch",
            "route_request"
          ],
          "workflow": [
            "Read the user request and identify the primary intent.",
            "Determine whether the task is single-domain (frontend only or backend only) or multi-domain (both frontend and backend).",
            "For single-domain frontend tasks, write handoff:{taskId} to Engram and delegate to frontend-orchestrator.",
            "For single-domain backend tasks, write handoff:{taskId} to Engram and delegate to backend-orchestrator.",
            "For UI analysis tasks, delegate directly to ui-analyst-worker.",
            "For multi-domain tasks, write task:{taskId}:subtask:frontend and task:{taskId}:subtask:backend to Engram and call agent-teams-dispatch-parallel.",
            "If no agent matches the detected intent, escalate with a clear explanation."
          ],
          "tools": [
            {
              "name": "agent-teams-handoff"
            }
          ],
          "handoffs": {
            "delegates_to": [
              "frontend-orchestrator",
              "backend-orchestrator",
              "ui-analyst-worker"
            ]
          },
          "output": {
            "template": "routing-decision",
            "mode": "short"
          }
        }
      },
      "ui-analyst-worker": {
        "id": "ui-analyst-worker",
        "source": "import",
        "updatedAt": "2026-03-19T00:34:47.364Z",
        "data": {
          "id": "ui-analyst-worker",
          "name": "UI Analyst Worker",
          "version": "1.0.0",
          "role": "worker",
          "domain": "frontend",
          "subdomain": "analysis",
          "description": "Analyzes all React components in src/ui/ to identify which ones lack a corresponding test file. Uses Engram to persist analysis results and returns cached results instantly on repeat requests without re-scanning the filesystem.\n",
          "expertise": [
            "React component analysis",
            "Vitest test coverage",
            "filesystem traversal",
            "Engram memory recall",
            "test gap identification"
          ],
          "intents": [
            "analyze_ui_components",
            "find_untested_components",
            "recall_ui_analysis"
          ],
          "scope": {
            "topics": [
              "UI component test coverage analysis",
              "missing test detection"
            ],
            "path_globs": [
              {
                "pattern": "src/ui/**",
                "priority": "high"
              }
            ],
            "excludes": [
              "node_modules/**",
              "dist/**"
            ]
          },
          "workflow": [
            "At session start, call engram_recall with key ui:analysis:{date} to check for a cached result.",
            "If a cached result exists and is recent, return it immediately without scanning the filesystem.",
            "If no cache exists, traverse src/ui/ and collect all component files (*.tsx, excluding *.test.tsx).",
            "For each component file, check whether a co-located .test.tsx file exists.",
            "Compile the list of components without test coverage.",
            "Write the analysis result to Engram with key ui:analysis:{date}.",
            "Return the analysis result with the full list of untested components."
          ],
          "tools": [
            {
              "name": "search/codebase"
            }
          ],
          "permissions": {
            "can_create_files": false,
            "can_edit_files": false,
            "can_delete_files": false,
            "can_run_commands": false,
            "can_delegate": false,
            "can_modify_public_api": false,
            "can_touch_global_config": false
          },
          "engram": {
            "mode": "autonomous"
          },
          "mcpServers": [
            {
              "id": "engram",
              "command": "engram",
              "args": []
            }
          ],
          "constraints": {
            "always": [
              "Check Engram for a cached analysis result before scanning the filesystem.",
              "Write every new analysis result to Engram immediately after computing it.",
              "Include the full file path for each component in the output."
            ],
            "never": [
              "Modify any source file.",
              "Scan directories outside src/ui/."
            ]
          },
          "handoffs": {
            "receives_from": [
              "router"
            ]
          },
          "output": {
            "template": "analysis",
            "mode": "detailed",
            "max_items": 20
          }
        }
      }
